---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE, getCanonicalUrl } from '@/lib/site';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const { title, description = SITE.description, canonicalPath = Astro.url.pathname } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.name}` : SITE.title;
const canonicalUrl = getCanonicalUrl(canonicalPath);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts: serif for reading, mono for code -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&family=JetBrains+Mono:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{pageTitle}</title>

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
  </head>
  <body>
    <a class="skip-link" href="#main">跳到正文</a>
    <div class="site-shell">
      <Header currentPath={Astro.url.pathname} />
      <main id="main" class="site-main site-container">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

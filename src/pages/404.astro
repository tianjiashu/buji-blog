---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到" description="这个页面暂时不存在。">
  <section class="intro animate-fade-in" aria-labelledby="not-found-title">
    <p class="eyebrow">404</p>
    <h1 id="not-found-title" class="page-title">这页还没写。</h1>
    <p class="lead">也许它会在以后出现。现在可以先回到随笔目录，找一篇已经放好的文章。</p>
    <p class="lead">
      <a href="/writing" style="color: var(--color-buji-accent); text-decoration: underline;">返回随笔</a>
    </p>
  </section>
</BaseLayout>

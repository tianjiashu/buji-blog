---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { getAdjacentBlog, getPublishedBlog } from '@/lib/content';

export async function getStaticPaths() {
  const articles = getPublishedBlog(await getCollection('blog'));

  return articles.map((article) => ({
    params: { slug: article.id },
    props: {
      article,
      ...getAdjacentBlog(articles, article.id),
    },
  }));
}

const { article, previous, next } = Astro.props;
const { Content } = await render(article);
---

<ArticleLayout article={article} previous={previous} next={next}>
  <Content />
</ArticleLayout>

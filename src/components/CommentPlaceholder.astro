---
interface Props {
  itemSlug: string;
}

const { itemSlug } = Astro.props;
---

<section class="comment-board" aria-labelledby="comments-title" data-article-slug={itemSlug}>
  <h2 id="comments-title">🍂 共鸣与讨论</h2>
  <p>
    匿名留言板。在这里，你可以留下对这篇文章的感悟与思考。
    不急，慢慢组织语言。千江有水千江月，期待你的静心留言。
  </p>

  <form class="comment-form" data-comment-form>
    <div class="comment-form__grid">
      <label>
        <span>署名</span>
        <input name="authorName" maxlength="24" autocomplete="nickname" placeholder="匿名读者" />
      </label>
      <label class="comment-form__trap">
        <span>网址</span>
        <input name="trap" tabindex="-1" autocomplete="off" />
      </label>
    </div>
    <label>
      <span>留言</span>
      <textarea name="content" minlength="2" maxlength="600" required rows="5" placeholder="写下你停留在这里的理由。"></textarea>
    </label>
    <div class="comment-form__footer">
      <span data-comment-count>0 / 600</span>
      <button type="submit">寄出留言</button>
    </div>
    <p class="comment-board__status" data-comment-status aria-live="polite"></p>
  </form>

  <div class="comment-list" data-comment-list aria-live="polite"></div>
</section>

<script>
  import '@/scripts/comment-board';
</script>
